NODE_ENV=development
PORT=4000
MONGO_URI=mongodb://localhost:27017/focusme

JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=15m
JWT_ISSUER=focusme-api
JWT_AUDIENCE=focusme-mobile

APP_BASE_URL=http://localhost:4000
MAIL_FROM=FocusMe <no-reply@focusme.app>

GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_ANDROID_CLIENT_ID=your_android_client_id
GOOGLE_WEB_CLIENT_ID=your_web_client_id

GMAIL_CLIENT_ID=your_gmail_oauth_client_id
GMAIL_CLIENT_SECRET=your_gmail_oauth_client_secret
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token
GMAIL_USER=your_sender_email

CORS_ORIGIN=*
CORS_CREDENTIALS=false
TRUST_PROXY=false
ENFORCE_HTTPS=false
HTTPS_ENABLED=false
HTTPS_KEY_PATH=
HTTPS_CERT_PATH=

AUTH_RATE_LIMIT_MAX=60
LOGIN_RATE_LIMIT_MAX=10
SIGNUP_RATE_LIMIT_MAX=8
